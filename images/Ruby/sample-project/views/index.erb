<div class="row">
    <div class="col-md-12">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2>Users</h2>
            <div>
                <a href="/add" class="btn btn-primary">Add New User</a>
                <form method="post" action="/reset" style="display: inline;" onsubmit="return confirm('Are you sure you want to reset the database? This will delete all users.')">
                    <button type="submit" class="btn btn-warning">Reset Database</button>
                </form>
            </div>
        </div>
        
        <% if @users.empty? %>
            <div class="alert alert-info">
                <h4 class="alert-heading">No users found!</h4>
                <p>Get started by adding your first user.</p>
                <hr>
                <a href="/add" class="btn btn-primary">Add User</a>
            </div>
        <% else %>
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Created At</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% @users.each do |user| %>
                            <tr>
                                <td><%= user['id'] %></td>
                                <td><%= user['name'] %></td>
                                <td><%= user['email'] %></td>
                                <td><%= user['created_at'] %></td>
                                <td>
                                    <form method="post" action="/delete/<%= user['id'] %>" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this user?')">
                                        <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        <% end %>
                    </tbody>
                </table>
            </div>
            
            <div class="mt-3">
                <small class="text-muted">
                    Total users: <%= @users.length %>
                </small>
            </div>
        <% end %>
    </div>
</div>

<div class="row mt-4">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">API Endpoints</h5>
            </div>
            <div class="card-body">
                <p class="card-text">This application also provides REST API endpoints:</p>
                <ul class="list-unstyled">
                    <li><code>GET /api/users</code> - Get all users</li>
                    <li><code>POST /api/users</code> - Create a new user</li>
                    <li><code>GET /api/users/:id</code> - Get a specific user</li>
                    <li><code>DELETE /api/users/:id</code> - Delete a user</li>
                    <li><code>GET /health</code> - Health check</li>
                </ul>
            </div>
        </div>
    </div>
</div>
